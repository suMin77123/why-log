#!/usr/bin/env bash
# SessionStart hook for why-log plugin
# Injects bootstrap context with decision logging instructions into each session.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Count existing decision logs in the current project
DECISION_COUNT=0
if [ -d "docs/decisions" ]; then
    DECISION_COUNT=$(find docs/decisions -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
fi

# Read bootstrap context file and substitute placeholders
BOOTSTRAP_CONTENT=$(cat "${PLUGIN_ROOT}/hooks/bootstrap-context.md" 2>&1 || echo "Error reading bootstrap context")
BOOTSTRAP_CONTENT="${BOOTSTRAP_CONTENT//\{\{DECISION_COUNT\}\}/$DECISION_COUNT}"

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass — fast and portable.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

ESCAPED=$(escape_for_json "$BOOTSTRAP_CONTENT")

# Output context injection as JSON
# Cursor expects additional_context, Claude Code expects hookSpecificOutput.additionalContext
# Only emit the field for the current platform to avoid double injection.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$ESCAPED"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$ESCAPED"
else
    printf '{\n  "additional_context": "%s"\n}\n' "$ESCAPED"
fi

exit 0
