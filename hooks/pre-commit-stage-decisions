#!/usr/bin/env bash
# Git pre-commit hook: auto-stage any new or modified decision logs.
#
# Install (choose one):
#   cp hooks/pre-commit-stage-decisions .git/hooks/pre-commit
#   ln -s ../../hooks/pre-commit-stage-decisions .git/hooks/pre-commit
#
# If you already have a pre-commit hook, add the contents of this script
# to your existing hook.

if [ -d "docs/decisions" ]; then
    # Stage modified decision logs
    git diff --name-only docs/decisions/ 2>/dev/null | while read -r file; do
        [ -n "$file" ] && git add "$file"
    done

    # Stage new (untracked) decision logs
    git ls-files --others --exclude-standard docs/decisions/ 2>/dev/null | while read -r file; do
        [ -n "$file" ] && git add "$file"
    done
fi
